# AMPass Installer Protection
# After installation, DELETE the entire /install/ directory.
#
# This .htaccess provides defense-in-depth:
# - The main .htaccess blocks /install/ when config.php or .install_lock exists
# - The installer PHP code also checks INSTALL_LOCKED constant
# - This file blocks non-index.php files from being accessed directly

# Block all file types except the installer index.php and its assets
<FilesMatch "^(?!index\.php$)">
    Order allow,deny
    Deny from all
</FilesMatch>
