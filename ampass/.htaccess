# AMPass - Apache Configuration
# Compatible with XAMPP and cPanel shared hosting.

RewriteEngine On

# ============================================================
# HTTPS ENFORCEMENT (UNCOMMENT FOR PRODUCTION - REQUIRED!)
# ============================================================
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prevent directory listing
Options -Indexes

# ============================================================
# BLOCK SENSITIVE DIRECTORIES
# ============================================================

# Block direct access to config directory (always)
RewriteRule ^config/ - [F,L]

# Block direct access to app directory
RewriteRule ^app/ - [F,L]

# Block direct access to database directory
RewriteRule ^database/ - [F,L]

# Block direct access to docs directory
RewriteRule ^docs/ - [F,L]

# Block direct access to app_storage directory
RewriteRule ^app_storage/ - [F,L]

# ============================================================
# INSTALL DIRECTORY — conditional access
# Accessible ONLY when config/config.php does NOT exist (fresh install).
# After installation, PHP-level locks block access even if directory remains.
# Best practice: DELETE /install/ after setup.
# ============================================================
# Note: We do NOT block /install/ in .htaccess because Apache cannot
# reliably check sibling file existence across all hosting environments.
# The installer has 3 PHP-level locks (INSTALL_LOCKED, .install_lock, rate limit).

# ============================================================
# BLOCK SENSITIVE FILES
# ============================================================
<FilesMatch "\.(env|sql|md|lock|log|bak|inc|ini|sh|yml|yaml|toml)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block dotfiles (except .htaccess itself)
<FilesMatch "^\.(?!htaccess)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block README
RewriteRule ^README\.md$ - [F,L]

# ============================================================
# STATIC ASSETS — serve directly
# ============================================================
RewriteCond %{REQUEST_URI} ^(.*/)?public/ [OR]
RewriteCond %{REQUEST_URI} ^(.*/)?install/ [OR]
RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|webmanifest)$ [NC]
RewriteRule ^ - [L]

# Service worker must be served from root
RewriteRule ^sw\.js$ - [L]
RewriteRule ^manifest\.webmanifest$ - [L]

# ============================================================
# FRONT CONTROLLER — route everything else to index.php
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set X-Permitted-Cross-Domain-Policies "none"
    Header always unset X-Powered-By
    Header always unset Server
    # Uncomment for production HTTPS:
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ============================================================
# PHP SETTINGS
# ============================================================
<IfModule mod_php.c>
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
    php_value session.use_only_cookies 1
    php_value expose_php Off
    php_value display_errors Off
    php_value log_errors On
    php_value upload_max_filesize 10M
    php_value post_max_size 52M
    php_value max_execution_time 30
</IfModule>

FileETag None
