{
    "productName": "AMPass",
    "version": "1.72.0",
    "identifier": "com.ampass.desktop",
    "build": {
        "frontendDist": "../src",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "AMPass - Secure Vault",
                "width": 900,
                "height": 650,
                "minWidth": 600,
                "minHeight": 500,
                "center": true,
                "resizable": true,
                "decorations": true,
                "visible": true
            }
        ],
        "trayIcon": {
            "iconPath": "icons/icon.png",
            "iconAsTemplate": false,
            "tooltip": "AMPass - Vault Locked"
        },
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://* http://localhost http://localhost:* http://127.0.0.1 http://127.0.0.1:*"
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "msi",
            "nsis"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/icon.ico"
        ],
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        }
    }
}
