# AMPass Project - Root .gitignore

# PHP app secrets (generated by installer)
ampass/config/config.php
ampass/config/.install_lock

# Rust build artifacts
clients/desktop-tauri/src-tauri/target/
clients/desktop-tauri/src-tauri/gen/

# Release build output
release/dist/

# Node modules
node_modules/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Environment files with secrets
.env
.env.local
.env.production
